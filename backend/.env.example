# Cấu hình server
PORT=5001
NODE_ENV=development

# Cấu hình Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=personal_calendar_db

# Cấu hình bảo mật
JWT_SECRET=your_super_secret_key_12345

# Cấu hình NVIDIA AI (GPT 120B)
NVIDIA_API_KEY=your_nvidia_api_key_here
BASE_URL=https://integrate.api.nvidia.com/v1

# ========================================================
# CẤU HÌNH ĐỒNG BỘ EMAIL VÀ GỬI THÔNG BÁO QUA TELEGRAM (0Đ)
# ========================================================
ENABLE_AUTOMATION=true
EMAIL_SYNC_INTERVAL_MINUTES=5

# Cấu hình Gmail IMAP
# Cách lấy App Password: Vào Cài đặt tài khoản Google -> Security -> 2-Step Verification -> App passwords
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password_here
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_TLS=true

# Cấu hình Discord Webhook
# Cách lấy URL: Vào Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

